# ═══════════════════════════════════════════════════════════════════════════════
# Atlassian Clone — Variables d'environnement
# Copier ce fichier en .env et remplir toutes les valeurs
# IMPORTANT : Ne jamais committer .env dans git !
# ═══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# Nom de la base de données
POSTGRES_DB=atlassian

# Utilisateur PostgreSQL
POSTGRES_USER=atlassian

# Mot de passe PostgreSQL — CHANGER pour une valeur forte et aléatoire !
# Exemple de génération : openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_use_openssl_rand_base64_32

# ── Backend Node.js ────────────────────────────────────────────────────────────
# Environnement d'exécution : development | production | test
NODE_ENV=production

# Port du serveur Express
PORT=4000

# Secret JWT — OBLIGATOIRE, doit être long et aléatoire !
# Exemple de génération : openssl rand -base64 64
JWT_SECRET=CHANGE_ME_use_openssl_rand_base64_64

# Durée de validité des tokens JWT (ex: 24h, 7d, 1h)
JWT_EXPIRES_IN=24h

# Nombre de rounds bcrypt pour le hashage des mots de passe
# 12 = bon équilibre sécurité/performance (augmenter pour plus de sécurité)
BCRYPT_ROUNDS=12

# Origines autorisées pour CORS (séparées par virgule, sans espace)
# En production : mettre uniquement votre domaine
CORS_ORIGINS=http://localhost,http://localhost:80

# ── Frontend (optionnel) ───────────────────────────────────────────────────────
# Port exposé pour Nginx (défaut : 80)
FRONTEND_PORT=80

ADMIN_EMAIL=incompris@example.com
ADMIN_USERNAME='incompris incompris'
ADMIN_PASSWORD=Mot2Pass

# ── Agents AI — LLM Provider ───────────────────────────────────────────────────
# Fournisseur LLM : mock | openai | anthropic | ollama
# "mock" permet de développer sans clé API (réponses simulées)
LLM_PROVIDER=mock

# OpenAI (si LLM_PROVIDER=openai)
# Obtenir sur https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude (si LLM_PROVIDER=anthropic)
# Obtenir sur https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Ollama (si LLM_PROVIDER=ollama — modèle local, pas de clé API)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Agents AI — Orchestrateur ──────────────────────────────────────────────────
# Timeout maximum par tâche en millisecondes (défaut : 10 minutes)
AGENT_TASK_TIMEOUT_MS=600000

# Nombre maximum de tentatives en cas d'échec
AGENT_MAX_RETRIES=3

# Intervalle de polling de la file d'attente en millisecondes
AGENT_QUEUE_POLL_INTERVAL_MS=5000

# ── Agents AI — Confluence auto-génération ─────────────────────────────────────
# Créer automatiquement une page Confluence après chaque tâche terminée
# true | false (défaut : true)
AI_AUTO_CREATE_CONFLUENCE=true

# Espace Confluence par défaut pour les pages générées par les agents
AI_CONFLUENCE_SPACE_DEFAULT=TEAM

# ── Agents AI — Sélection automatique ──────────────────────────────────────────
# Sélectionner automatiquement l'agent selon le type d'issue si aucun n'est assigné
# true | false (défaut : true)
AI_AUTO_SELECT_AGENT=true

# ── Sandbox ─────────────────────────────────────────────────────────────────────
# Timeout maximum d'exécution dans le sandbox (millisecondes)
SANDBOX_TIMEOUT_MS=30000

# Limite mémoire du sandbox (Mo)
SANDBOX_MEMORY_MB=256

# ── Frontend (Vite) ─────────────────────────────────────────────────────────────
# URL de l'API backend (utilisé par Vite côté frontend)
VITE_API_URL=http://localhost:4000

# URL WebSocket (partage le même port que l'API, chemin /ws)
VITE_WS_URL=ws://localhost:4000