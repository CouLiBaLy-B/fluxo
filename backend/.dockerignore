.git
.gitattributes
.gitignore

# IDE
.vscode
.idea
*.swp
*.swo

# Fichiers OS Windows/Mac
Thumbs.db
.DS_Store

# Tests — non nécessaires en production
*.test.ts
*.spec.ts
__tests__
coverage
