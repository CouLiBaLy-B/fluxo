# Forcer LF pour tous les fichiers texte sur Windows
* text=auto eol=lf

# Scripts shell — toujours LF (sinon bash échoue sous Linux/Mac)
*.sh   text eol=lf
*.bash text eol=lf

# Docker — toujours LF
Dockerfile      text eol=lf
*.dockerfile    text eol=lf
.dockerignore   text eol=lf

# Configuration — toujours LF
*.json     text eol=lf
*.yaml     text eol=lf
*.yml      text eol=lf
*.toml     text eol=lf
*.ini      text eol=lf
*.env      text eol=lf
*.env.*    text eol=lf

# Code source — toujours LF
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.sql  text eol=lf
*.md   text eol=lf

# Nginx
*.conf text eol=lf

# Binaires — ne pas modifier
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.otf   binary
*.zip   binary
*.gz    binary
*.tar   binary
